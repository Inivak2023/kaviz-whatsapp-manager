{
  "name": "whatsapp-multi",
  "version": "2.0.0",
  "description": "Multi-Account WhatsApp Manager",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.kaviz.whatsapp",
    "productName": "Kaviz Whatsapp Manager",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "logo.png"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Inivak2023",
        "repo": "kaviz-whatsapp-manager"
      }
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3"
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  }
}
